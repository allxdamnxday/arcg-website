# Copy to .env.local and fill in. .env.local is gitignored.

# Resend API key — required; /api/contact returns 500 without it.
RESEND_API_KEY=

# Optional: inbox that receives inquiries (default info@arcontractglazing.com).
CONTACT_TO_EMAIL=

# Optional: verified-domain sender, e.g. "ARCG Website <no-reply@arcontractglazing.com>".
# Setting this also enables the confirmation email back to submitters. Requires the
# domain to be verified in Resend (SPF/DKIM DNS). Without it, sends use the default
# onboarding@resend.dev sender and no confirmation email is sent.
CONTACT_FROM_EMAIL=
